rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "gujjupanchat0@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/staff/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'super_admin')
      );
    }

    function isStaff() {
      return isAuthenticated() && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }

    function getStaffData() {
      return get(/databases/$(database)/documents/staff/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSuperAdmin() || (isStaff() && getStaffData().role == 'admin');
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isRecent(timestamp) {
      return timestamp is timestamp && 
             timestamp > request.time - duration.value(5, 'm') &&
             timestamp < request.time + duration.value(5, 'm');
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == companyId);
      allow create: if isSuperAdmin() || isAuthenticated(); // Allow signup to create company
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == companyId && getStaffData().role == 'admin');
      allow delete: if isSuperAdmin();
    }

    // Staff
    match /staff/{staffId} {
      allow read: if isAuthenticated() && (request.auth.uid == staffId || isSuperAdmin());
      allow read: if isStaff() && resource != null && getStaffData().companyId == resource.data.companyId;
      
      allow create: if isAuthenticated() && (request.auth.uid == staffId || isSuperAdmin());
      allow update: if isSuperAdmin() || (
        isStaff() && 
        getStaffData().companyId == resource.data.companyId && 
        getStaffData().role == 'admin' &&
        request.resource.data.role == resource.data.role // Cannot change role unless super admin
      );
      allow delete: if isSuperAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow create: if isSuperAdmin() || (isStaff() && getStaffData().companyId == request.resource.data.companyId);
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId && getStaffData().role == 'admin');
    }

    // Items
    match /items/{itemId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow create: if isSuperAdmin() || (isStaff() && getStaffData().companyId == request.resource.data.companyId);
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId && getStaffData().role == 'admin');
    }

    // Estimates
    match /estimates/{estimateId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow create: if isSuperAdmin() || (isStaff() && getStaffData().companyId == request.resource.data.companyId);
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId && getStaffData().role == 'admin');
    }

    // Reminders
    match /reminders/{reminderId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow create: if isSuperAdmin() || (isStaff() && getStaffData().companyId == request.resource.data.companyId);
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId && getStaffData().role == 'admin');
    }

    // CRM History
    match /crmHistory/{historyId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow create: if isSuperAdmin() || (isStaff() && getStaffData().companyId == request.resource.data.companyId);
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId && getStaffData().role == 'admin');
    }

    // Settings
    match /settings/landingPage {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /settings/support {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Packages
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Projects
    match /projects/{projectId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow create: if isSuperAdmin() || (isStaff() && getStaffData().companyId == request.resource.data.companyId);
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId && getStaffData().role == 'admin');
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow create: if isSuperAdmin() || (isStaff() && getStaffData().companyId == request.resource.data.companyId);
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId && getStaffData().role == 'admin');
    }

    // Daily Reports
    match /dailyReports/{reportId} {
      allow read: if isSuperAdmin() || (isStaff() && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.companyId == getStaffData().companyId);
      allow create: if isStaff() && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.companyId == getStaffData().companyId;
      allow update: if isSuperAdmin() || (isStaff() && request.auth.uid == resource.data.staffId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().role == 'admin' && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.companyId == getStaffData().companyId);
    }

    // Payment Receipts
    match /paymentReceipts/{receiptId} {
      allow read: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow create: if isSuperAdmin() || (isStaff() && getStaffData().companyId == request.resource.data.companyId);
      allow update: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId);
      allow delete: if isSuperAdmin() || (isStaff() && getStaffData().companyId == resource.data.companyId && getStaffData().role == 'admin');
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
