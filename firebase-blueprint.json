{
  "entities": {
    "companySettings": {
      "title": "Company Settings",
      "description": "Global settings for the company including branding and limits.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "address": { "type": "string" },
        "gst": { "type": "string" },
        "pan": { "type": "string" },
        "tan": { "type": "string" },
        "themeColor": { "type": "string" },
        "staffLimit": { "type": "number" },
        "ownerSignature": { "type": "string" }
      },
      "required": ["name"]
    },
    "staff": {
      "title": "Staff",
      "description": "Staff members with access to the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "uid": { "type": "string" }
      },
      "required": ["name", "email", "role"]
    },
    "client": {
      "title": "Client",
      "description": "Client information and project details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "currentAddress": { "type": "string" },
        "siteAddress": { "type": "string" },
        "mob1": { "type": "string" },
        "mob2": { "type": "string" },
        "projectType": { "type": "string", "enum": ["Turnkey", "Box", "Renovation", "Interior"] },
        "projectCategory": { "type": "string", "enum": ["Residential", "Commercial", "Industrial"] },
        "budget": { "type": "number" },
        "details": { "type": "string" }
      },
      "required": ["name", "mob1"]
    },
    "item": {
      "title": "Item",
      "description": "Catalog of construction items/services.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "gst": { "type": "number" }
      },
      "required": ["name", "price"]
    },
    "estimate": {
      "title": "Estimate",
      "description": "Project estimates generated for clients.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "viewed", "revision"] },
        "revisions": { "type": "number" },
        "terms": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "items"]
    },
    "reminder": {
      "title": "Reminder",
      "description": "Follow-up reminders for clients.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "done", "renew"] },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "dueDate"]
    },
    "crmHistory": {
      "title": "CRM History",
      "description": "Log of interactions with clients.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "type": { "type": "string", "enum": ["chat", "call", "meeting"] },
        "notes": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "type", "timestamp"]
    },
    "inquiry": {
      "title": "Inquiry",
      "description": "Customer inquiries and leads.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "contactNumber": { "type": "string" },
        "emailId": { "type": "string" },
        "address": { "type": "string" },
        "source": { "type": "string" },
        "productInterested": { "type": "string" },
        "budget": { "type": "number" },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "lost", "converted"] },
        "estimateProvided": { "type": "boolean" },
        "contactDataAccess": { "type": "boolean" },
        "assignedTo": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["customerName", "contactNumber"]
    },
    "announcement": {
      "title": "Announcement",
      "description": "System-wide announcements from super admin.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "targetType": { "type": "string", "enum": ["all", "selected", "individual"] },
        "targetCompanyIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "targetType"]
    },
    "paymentSettings": {
      "title": "Payment Settings",
      "description": "Configuration for payment methods including Razorpay and UPI.",
      "type": "object",
      "properties": {
        "upiId": { "type": "string" },
        "upiName": { "type": "string" },
        "qrCodeUrl": { "type": "string" },
        "bankDetails": { "type": "string" },
        "instructions": { "type": "string" },
        "razorpayKeyId": { "type": "string" },
        "razorpayKeySecret": { "type": "string" },
        "enabledMethods": { "type": "array", "items": { "type": "string", "enum": ["razorpay", "upi"] } }
      },
      "required": ["enabledMethods"]
    },
    "pricingPackage": {
      "title": "Pricing Package",
      "description": "Subscription plans and add-ons available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "period": { "type": "string", "enum": ["monthly", "yearly", "one-time"] },
        "features": { "type": "array", "items": { "type": "string" } },
        "popular": { "type": "boolean" },
        "type": { "type": "string", "enum": ["subscription", "addon"] },
        "estimateLimit": { "type": "number" },
        "staffLimit": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "period", "type"]
    },
    "paymentReceipt": {
      "title": "Payment Receipt",
      "description": "Receipts for payments received from clients.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string", "format": "date" },
        "paymentMode": { "type": "string" },
        "receiptNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "amount", "paymentDate", "receiptNumber"]
    }
  },
  "firestore": {
    "settings/company": { "schema": "companySettings", "description": "Global company settings" },
    "settings/payment": { "schema": "paymentSettings", "description": "Payment gateway configuration" },
    "packages": { "schema": "pricingPackage", "description": "Available subscription packages" },
    "staff": { "schema": "staff", "description": "Staff members" },
    "clients": { "schema": "client", "description": "Client directory" },
    "items": { "schema": "item", "description": "Item catalog" },
    "estimates": { "schema": "estimate", "description": "Project estimates" },
    "reminders": { "schema": "reminder", "description": "Client follow-ups" },
    "crmHistory": { "schema": "crmHistory", "description": "Interaction logs" },
    "inquiries": { "schema": "inquiry", "description": "Customer inquiries" },
    "announcements": { "schema": "announcement", "description": "Super admin announcements" },
    "paymentReceipts": { "schema": "paymentReceipt", "description": "Client payment receipts" }
  }
}
